{
    "app_name": "NestConnect",
    "author": "",
    "dependencies": {
        "bcryptjs": "^3.0.3",
        "cookie-parser": "^1.4.7",
        "express": "^5.2.1",
        "jsonwebtoken": "^9.0.3",
        "socket.io": "^4.8.3"
    },
    "license": "ISC",
    "main": "main.js",
    "name": "nestconnect",
    "scripts": {
        "start": "node server.js",
        "electron": "electron .",
        "build-exe": "electron-builder build --win --publish never",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "build": {
        "appId": "com.alexnfymaker.nestconnect",
        "productName": "NestConnect",
        "win": {
            "target": [
                "nsis"
            ]
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "NestConnect"
        }
    },
    "type": "commonjs",
    "version": "1.0.0",
    "webkit": {},
    "window": {
        "frame": true,
        "id": "NestConnect",
        "resizable": true,
        "show": true,
        "show_in_taskbar": true,
        "title": "NestConnect",
        "visible": true
    },
    "devDependencies": {
        "electron": "^41.1.0",
        "electron-builder": "^26.8.1"
    }
}
